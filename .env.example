# Credentials for the web UI (managed via the Settings tab too).
# Copy to .env. Never commit the real .env.
SHIKI_CLIENT_ID=
SHIKI_CLIENT_SECRET=
# Leave blank to act on the token owner; or set a numeric id / nickname.
SHIKI_USER=
SHIKI_USER_AGENT=shikimori-manager
SHIKI_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob
SHIKI_BASE_URL=https://shikimori.one
SHIKI_REQUEST_DELAY=0.3
